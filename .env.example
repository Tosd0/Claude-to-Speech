# Claude-to-Speech Configuration
#
# Copy this file to `.env` and fill in your values.
# Everything except ELEVENLABS_API_KEY is optional.

# REQUIRED: ElevenLabs API key (https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=your_api_key_here

# Voice selection. Accepts either a friendly name from scripts/claude_speak.py
# (laura, claude, rachel, domi, bella, antoni, arnold, adam, josh, ...)
# or a raw ElevenLabs voice ID.
CLAUDE_VOICE_ID=claude

# ElevenLabs model ID.
# Options:
#   eleven_flash_v2_5       - fastest, default, widest compatibility
#   eleven_turbo_v2         - balanced speed/quality
#   eleven_multilingual_v2  - multilingual
#   eleven_v3               - latest; supports inline audio tags like
#                             [excited], [whispers], [laughs]
ELEVENLABS_MODEL=eleven_flash_v2_5

# TTS server URL (optional).
# Leave empty/commented to use direct ElevenLabs API mode.
# Set to your local server for shared/cached playback across devices.
# TTS_SERVER_URL=http://localhost:5001/tts

# Debug mode for the Stop hook.
# Set to 1 to enable logging to /tmp/claude_stop_hook.log.
DEBUG=0
